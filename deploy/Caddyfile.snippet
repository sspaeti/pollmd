# Append to your existing Caddyfile, then `service caddy reload`.
#
# Caddy auto-provisions Let's Encrypt certs for both hosts. DNS records:
#   ti.sspaeti.duckdns.org     A  <your public IP>
#   quack.sspaeti.duckdns.org  A  <your public IP>
# (Or CNAME both to ti.sspaeti.duckdns.org.)

ti.sspaeti.duckdns.org {
    encode gzip
    reverse_proxy 127.0.0.1:8080
}

quack.sspaeti.duckdns.org {
    reverse_proxy 127.0.0.1:9494
}
